# Supabase (나중에 추가)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Kakao OAuth (나중에 추가)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Kakao 상담 채널 (https://center-pf.kakao.com 에서 채널 만든 후 URL 입력)
# 예: https://pf.kakao.com/_xxxxxxx
NEXT_PUBLIC_KAKAO_CHANNEL_URL=

# Kakao 봇/비즈채널 메시지 API 엔드포인트 (선택)
# 설정하면 ChatWidget이 정적 flow 대신 이 엔드포인트로 fetch (POST /select, /message, GET /start)
# 미설정 시 lib/chat-flow.ts의 정적 트리에서 응답
NEXT_PUBLIC_KAKAO_CHAT_API=

# TossPayments
# 미설정 시 Toss 공개 게스트 테스트 키가 자동 사용됨 — 즉시 시연 가능 (실제 결제 X)
# 운영 전환: tosspayments.com 가맹점 등록 후 발급받은 라이브 키로 교체
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# NEXT_PUBLIC_TOSS_DISABLED=1 로 두면 결제 위젯을 끄고 기존 데모(800ms) 모드로 동작
NEXT_PUBLIC_TOSS_DISABLED=

# 가상계좌 입금 통지 등 비동기 결제 이벤트는 Toss 대시보드 > 웹훅에
# https://<배포도메인>/api/webhooks/toss 를 등록해야 수신됩니다. (별도 시크릿 불필요 — 서버가 결제를 재조회해 검증)

# 트랜잭션 이메일 (Resend — 선택)
# 미설정 시 주문확인/배송/환불 이메일을 자동으로 건너뜁니다(기능 정상).
# resend.com 가입 후 API 키 발급, 발신 도메인 인증 권장.
RESEND_API_KEY=
# 발신자. 예: The Nature Academy <noreply@yourdomain.com>
EMAIL_FROM=

# 사이트 절대 URL (이메일 링크/배송조회 등에 사용, 미설정 시 localhost:3000)
NEXT_PUBLIC_SITE_URL=
